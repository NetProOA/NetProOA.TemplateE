using Microsoft.EntityFrameworkCore;
using Microsoft.EntityFrameworkCore.Metadata.Builders;
using SaaS.Framework.Domain.Core.EF.Extension;
using SaaS.TemplateE.Domain.AggregateModels.<#= entity.EntityName #>Aggregate;

namespace SaaS.TemplateE.Entity.Mapper
{
    public  class <#= entity.EntityName #>Map : EntityMappingConfiguration<<#= entity.EntityName #>>
    {
        public override void Map(EntityTypeBuilder<<#= entity.EntityName #>> t)
        {
             t.ToTable("<#= entity.EntityName #>s").ToTable(p=>p.HasComment("示例表"));
             t.Property(p => p.RowVersion).IsRowVersion().HasComment("版本号");
             
			 t.HasKey(p => p.Id);
             t.Property(p => p.Id).UseIdentityColumn().IsRequired().HasComment("主键ID");
             t.Ignore(b => b.ExtraProperties);
			
			 #region 系统字段
			 t.Property(p => p.CreateEmplId).HasMaxLength(50).IsRequired().HasDefaultValue(string.Empty).HasComment("创建人ID");
			 t.Property(p => p.CreateEmplName).HasMaxLength(50).IsRequired().HasDefaultValue(string.Empty).HasComment("创建人"); 
			 t.Property(p => p.CreateDeptId).HasMaxLength(50).IsRequired().HasDefaultValue(string.Empty).HasComment("创建人部门ID");
			 t.Property(p => p.CreateDeptName).HasMaxLength(50).IsRequired().HasDefaultValue(string.Empty).HasComment("创建人部门");
			 t.Property(p => p.LastModifyEmplId).HasMaxLength(50).IsRequired().HasDefaultValue(string.Empty).HasComment("最近修改人ID");
			 t.Property(p => p.LastModifyEmplName).HasMaxLength(50).IsRequired().HasDefaultValue(string.Empty).HasComment("最近修改人");  
			 t.Property(p => p.LastModifyDeptId).HasMaxLength(50).IsRequired().HasDefaultValue(string.Empty).HasComment("最近修改人部门ID"); 
			 t.Property(p => p.LastModifyDeptName).HasMaxLength(50).IsRequired().HasDefaultValue(string.Empty).HasComment("最近修改人部门");

			 t.Property(p => p.CreateTime).IsRequired().HasComment("创建时间");
			 t.Property(p => p.UpdateTime).IsRequired().HasComment("修改时间");
			 #endregion
        }
    }
}

