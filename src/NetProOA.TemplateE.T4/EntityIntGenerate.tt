namespace SaaS.TemplateE.Domain.AggregateModels.<#= entity.EntityName #>Aggregate.Specifications
{
    public class Match<#= entity.EntityName #>ByIdsSpecification : Specification<<#= entity.EntityName #>>
    {
        public List<int> Ids { get; }

        public Match<#= entity.EntityName #>ByIdsSpecification(List<int> ids)
        {
            Ids = ids??new List<int>();
        }

        public override Expression<Func<<#= entity.EntityName #>, bool>> GetExpression()
