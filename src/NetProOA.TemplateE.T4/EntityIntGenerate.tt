namespace SaaS.TemplateE.Application.Commands.<#= entity.EntityName #>.Handlers
{
    public class Delete<#= entity.EntityName #>CommandHandler : IRequestHandler<Delete<#= entity.EntityName #>Command, bool>
    {
        private readonly IDbContext _dbContext;
        private readonly I<#= entity.EntityName #>Repository _<#= firstWordLowercase #>Repository;

        public Delete<#= entity.EntityName #>CommandHandler(IDbContext dbContext, I<#= entity.EntityName #>Repository <#= firstWordLowercase #>Repository)
