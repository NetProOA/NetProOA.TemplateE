            _<#= firstWordLowercase #>Repository = <#= firstWordLowercase #>Repository;
        }

        public async Task<bool> Handle(Delete<#= entity.EntityName #>Command request, CancellationToken cancellationToken)
        {
            var user = request.UserIdentity;

            _dbContext.BeginTransaction();

            var <#= firstWordLowercase #>s =await _<#= firstWordLowercase #>Repository.GetListAsync(new Match<#= entity.EntityName #>ByIdsSpecification(request.Ids));
            foreach (var <#= firstWordLowercase #> in <#= firstWordLowercase #>s)
